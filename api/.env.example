# Example environment variables
ENV=development
DEBUG=1

# Database (either DATABASE_URL or the POSTGRES_* parts)
# DATABASE_URL=postgresql://user:pass@localhost:5432/telemetrics
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432
POSTGRES_DB=telemetrics

# Optional Mongo
# MONGO_URL=mongodb://localhost:27017/telemetrics

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# or use REDIS_URL=redis://:pass@host:6379/0

# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883
# MQTT_USERNAME=
# MQTT_PASSWORD=
MQTT_TLS=0

# JWT
JWT_SECRET=change_me
JWT_ALGORITHM=HS256
JWT_ACCESS_MINUTES=15
JWT_REFRESH_MINUTES=1440

# Alerts
ALERT_SPEED_LIMIT_KPH=120
ALERT_ENGINE_TEMP_HIGH_C=110
ALERT_FUEL_THEFT_LITERS_DELTA=5
ALERT_HARSH_ACCEL_G=0.35
ALERT_HARD_BRAKE_G=0.4

# API rate limits
API_RPM=120
API_BURST=240
